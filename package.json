{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npx tsc && npx tsc-alias",
    "build:bundle": "node scripts/build-production-bundles.js",
    "build:prod": "npm run build && npm run build:bundle",
    "artisan": "ts-node -r tsconfig-paths/register src/console/artisan.ts",
    "boost": "ts-node -r tsconfig-paths/register scripts/boost.ts about",
    "boost:doctor": "ts-node -r tsconfig-paths/register scripts/boost.ts doctor",
    "boost:routes": "ts-node -r tsconfig-paths/register scripts/boost.ts routes",
    "db:make:migration": "knex migrate:make -x ts --knexfile knexfile.ts",
    "db:migrate": "knex migrate:latest --knexfile knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "db:seed": "knex seed:run --knexfile knexfile.ts",
    "db:status": "knex migrate:list --knexfile knexfile.ts",
    "test": "NODE_ENV=test vitest run",
    "start": "node dist/app.js",
    "start:bundle": "node --enable-source-maps dist-bundle/app.js",
    "artisan:bundle": "node --enable-source-maps dist-bundle/artisan.js",
    "queue:work": "ts-node -r tsconfig-paths/register src/worker.ts",
    "queue:work:dist": "node dist/worker.js",
    "queue:work:bundle": "node --enable-source-maps dist-bundle/worker.js",
    "schedule:work": "ts-node -r tsconfig-paths/register src/scheduler.ts",
    "schedule:work:dist": "node dist/scheduler.js",
    "schedule:work:bundle": "node --enable-source-maps dist-bundle/scheduler.js",
    "dev": "nodemon"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.4",
    "commander": "^14.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ioredis": "^5.10.1",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "fishery": "^2.4.0",
    "nodemon": "^3.1.14",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
